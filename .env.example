# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Owner IDs (comma-separated Telegram numeric user IDs)
OWNER_IDS=123456789,987654321

# Database path
DB_PATH=bot_database.db

# Master key for encrypting AccessKey Secrets (generate a strong random key)
# Example: openssl rand -hex 32
MASTER_KEY=your_master_key_here_generate_with_openssl_rand_hex_32
